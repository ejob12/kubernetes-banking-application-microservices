pipeline {

    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
        timestamps()
        ansiColor('xterm')
    }

    environment {

        AWS_REGION      = "us-east-1"
        AWS_ACCOUNT_ID  = "101257774115"
        ECR_REGISTRY    = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

        IMAGE_TAG = ""
        SHORT_SHA = ""

    }

    stages {

        stage('Checkout Source Code') {

            steps {

                echo "Checking out Git repository..."

                checkout scm

                sh '''
                pwd
                ls -la
                git branch
                git log --oneline -5
                '''

            }

        }

        stage('Prepare Build') {

            steps {

                script {

                    echo "========================================="
                    echo "Preparing build..."

                    env.SHORT_SHA = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()

                    env.IMAGE_TAG = "${env.BUILD_NUMBER}-${env.SHORT_SHA}"

                    echo "Build Number : ${env.BUILD_NUMBER}"
                    echo "Commit SHA   : ${env.SHORT_SHA}"
                    echo "Image Tag    : ${env.IMAGE_TAG}"
                    echo "========================================="

                }

            }

        }

        stage('Validate Build Environment') {

            steps {

                sh '''
                set -e

                docker --version
                aws --version
                git --version
                node --version
                '''

            }

        }

        stage('Validate Repository') {

            steps {

                script {

                    def dockerfiles = [

                        "frontend/Dockerfile",
                        "gateway/Dockerfile",

                        "services/accounts/Dockerfile",
                        "services/admin/Dockerfile",
                        "services/ai/Dockerfile",
                        "services/analytics/Dockerfile",
                        "services/auth/Dockerfile",
                        "services/balancer/Dockerfile",
                        "services/deposits/Dockerfile",
                        "services/notifications/Dockerfile",
                        "services/profile/Dockerfile",
                        "services/transfers/Dockerfile"

                    ]

                    dockerfiles.each {

                        if (!fileExists(it)) {
                            error("Missing Dockerfile : ${it}")
                        }

                    }

                }

            }

        }
        stage('Ensure ECR Repositories') {

            steps {

                withAWS(
                    credentials: 'aws-credentials',
                    region: "${AWS_REGION}"
                ) {

                    script {

                        def repositories = [

                            "frontend",
                            "gateway",

                            "accounts",
                            "admin",
                            "ai",
                            "analytics",
                            "auth",
                            "balancer",
                            "deposits",
                            "notifications",
                            "profile",
                            "transfers"

                        ]

                        repositories.each { repo ->

                            sh """

                            if aws ecr describe-repositories \
                                --repository-name banking-app/${repo} \
                                --region ${AWS_REGION} >/dev/null 2>&1
                            then

                                echo "Repository exists -> banking-app/${repo}"

                            else

                                echo "Creating repository -> banking-app/${repo}"

                                aws ecr create-repository \
                                    --repository-name banking-app/${repo} \
                                    --image-scanning-configuration scanOnPush=true \
                                    --region ${AWS_REGION}

                            fi

                            """

                        }

                    }

                }

            }

        }

        stage('ECR Login') {

            steps {

                withAWS(
                    credentials: 'aws-credentials',
                    region: "${AWS_REGION}"
                ) {

                    script {

                        env.AWS_ACCOUNT_ID = sh(
                            script: "aws sts get-caller-identity --query Account --output text",
                            returnStdout: true
                        ).trim()

                        env.ECR_REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

                        echo "Logging into Amazon ECR..."
                        echo "Registry : ${env.ECR_REGISTRY}"

                        sh """

                        aws ecr get-login-password \
                        --region ${AWS_REGION} | docker login \
                        --username AWS \
                        --password-stdin ${env.ECR_REGISTRY}

                        """

                    }

                }

            }

        }

        stage('Build Docker Images') {

            steps {

                script {

                    def services = [

                        [repo: "frontend",      dockerfile: "frontend/Dockerfile"],
                        [repo: "gateway",       dockerfile: "gateway/Dockerfile"],

                        [repo: "accounts",      dockerfile: "services/accounts/Dockerfile"],
                        [repo: "admin",         dockerfile: "services/admin/Dockerfile"],
                        [repo: "ai",            dockerfile: "services/ai/Dockerfile"],
                        [repo: "analytics",     dockerfile: "services/analytics/Dockerfile"],
                        [repo: "auth",          dockerfile: "services/auth/Dockerfile"],
                        [repo: "balancer",      dockerfile: "services/balancer/Dockerfile"],
                        [repo: "deposits",      dockerfile: "services/deposits/Dockerfile"],
                        [repo: "notifications", dockerfile: "services/notifications/Dockerfile"],
                        [repo: "profile",       dockerfile: "services/profile/Dockerfile"],
                        [repo: "transfers",     dockerfile: "services/transfers/Dockerfile"]

                    ]

                    services.each { service ->

                        echo "========================================="
                        echo "Building ${service.repo}"
                        echo "========================================="

                        sh """

                        docker build \
                          -f ${service.dockerfile} \
                          -t ${ECR_REGISTRY}/banking-app/${service.repo}:${IMAGE_TAG} \
                          .

                        """

                    }

                }

            }

        }

        stage('Tag Latest Images') {

            steps {

                script {

                    def repositories = [

                        "frontend",
                        "gateway",

                        "accounts",
                        "admin",
                        "ai",
                        "analytics",
                        "auth",
                        "balancer",
                        "deposits",
                        "notifications",
                        "profile",
                        "transfers"

                    ]

                    repositories.each { repo ->

                        echo "Tagging ${repo}..."

                        sh """

                        docker tag \
                          ${ECR_REGISTRY}/banking-app/${repo}:${IMAGE_TAG} \
                          ${ECR_REGISTRY}/banking-app/${repo}:latest

                        """

                    }

                }

            }

        }

        stage('Push Images To Amazon ECR') {

            steps {

                withAWS(
                    credentials: 'aws-credentials',
                    region: "${AWS_REGION}"
                ) {

                    script {

                        def repositories = [

                            "frontend",
                            "gateway",

                            "accounts",
                            "admin",
                            "ai",
                            "analytics",
                            "auth",
                            "balancer",
                            "deposits",
                            "notifications",
                            "profile",
                            "transfers"

                        ]

                        repositories.each { repo ->

                            echo "========================================="
                            echo "Pushing ${repo}"
                            echo "========================================="

                            sh """

                            docker push \
                              ${ECR_REGISTRY}/banking-app/${repo}:${IMAGE_TAG}

                            docker push \
                              ${ECR_REGISTRY}/banking-app/${repo}:latest

                            """

                        }

                    }

                }

            }

        }

        stage('Cleanup Docker Images') {

            steps {

                sh '''

                set +e

                echo "========================================="
                echo "Cleaning Docker images..."
                echo "========================================="

                docker image prune -af
                docker builder prune -af
                docker container prune -f

                '''

            }

        }

    }

    post {

        success {

            echo ""
            echo "========================================="
            echo "PIPELINE COMPLETED SUCCESSFULLY"
            echo "========================================="
            echo "AWS Account : ${AWS_ACCOUNT_ID}"
            echo "Region      : ${AWS_REGION}"
            echo "Image Tag   : ${IMAGE_TAG}"
            echo "Registry    : ${ECR_REGISTRY}"
            echo "========================================="
            echo ""

        }

        failure {

            echo ""
            echo "========================================="
            echo "PIPELINE FAILED"
            echo "Review the failed stage above."
            echo "========================================="
            echo ""

        }

        always {

            sh '''

            docker logout ${ECR_REGISTRY} >/dev/null 2>&1 || true

            '''

        }

    }

}
