            }
          }
        }
      }
    }
    */
  }

  post {
    success {
      echo "LionTech Finance images pushed to ECR with tag ${env.IMAGE_TAG}"
      // Slack notifications disabled for now
    }
    failure {
      echo "LionTech Finance pipeline failed. Check the stage logs above."
      // Slack notifications disabled for now
    }
    always {
      sh 'docker logout $ECR_REGISTRY >/dev/null 2>&1 || true'
    }
  }
}
