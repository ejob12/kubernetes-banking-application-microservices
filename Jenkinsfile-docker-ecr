pipeline {
  agent any
  tools {
    git 'git' // ✅ Matches the Git installation you configured in Jenkins
  }
  options {
    buildDiscarder(logRotator(numToKeepStr: '20'))
    disableConcurrentBuilds()
    timestamps()
  }
  environment {
    APP_NAME        = 'liontech-finance'
    KUBE_NAMESPACE  = 'liontech-finance'
    ECR_REGISTRY    = '101257774115.dkr.ecr.us-east-1.amazonaws.com/banking-app'
    IMAGE_TAG       = ''
    K8S_MANIFEST    = 'k8s/liontech-finance.yaml'
    PROJECT_DIR     = '.'
    SLACK_CHANNEL   = '#jenkins-alerts'
    SLACK_TOKEN_ID  = 'slack-token'
  }
  stages {
    stage('Checkout') {
      steps {
        ansiColor('xterm') {
          checkout scm
        }
      }
    }

    stage('Prepare') {
      steps {
        ansiColor('xterm') {
          script {
            // ✅ Use Jenkins-provided GIT_COMMIT instead of git rev-parse
            if (env.GIT_COMMIT) {
              def shortCommit = env.GIT_COMMIT.take(7)
              env.IMAGE_TAG = "${env.BUILD_NUMBER}-${shortCommit}"
            } else {
              error("GIT_COMMIT not available. Aborting pipeline.")
            }

            if (fileExists('liontech-finance/docker-compose.yml')) {
              env.PROJECT_DIR = 'liontech-finance'
            } else {
              env.PROJECT_DIR = '.'
            }

            if (!env.IMAGE_TAG?.trim()) {
              error("IMAGE_TAG was not set. Aborting pipeline.")
            }
          }
          echo "Building ${env.APP_NAME} from ${env.PROJECT_DIR} with image tag ${env.IMAGE_TAG}"
        }
      }
    }

    stage('ECR Login') {
      steps {
        ansiColor('xterm') {
          withCredentials([amazonWebServices(credentialsId: 'aws-credentials')]) {
            sh '''
              aws ecr get-login-password --region us-east-1 | \
              docker login --username AWS --password-stdin $ECR_REGISTRY
            '''
          }
        }
      }
    }

    stage('Ensure ECR Repositories') {
      steps {
        ansiColor('xterm') {
          withCredentials([amazonWebServices(credentialsId: 'aws-credentials')]) {
            sh '''
              set -eu
              for image in frontend gateway auth profile accounts balancer notifications deposits transfers analytics ai admin; do
                aws ecr describe-repositories --repository-name banking-app/liontech-finance-$image --region us-east-1 >/dev/null 2>&1 || \
                aws ecr create-repository --repository-name banking-app/liontech-finance-$image --region us-east-1
              done
            '''
          }
        }
      }
    }

    stage('Validate') {
      steps {
        ansiColor('xterm') {
          dir(env.PROJECT_DIR) {
            sh '''
              set -eu
              node --check shared/src/auth.js
              node --check shared/src/http.js
              node --check shared/src/server.js
              node --check shared/src/store.js
              node --check gateway/src/index.js
              node --check services/auth/src/index.js
              node --check services/profile/src/index.js
              node --check services/accounts/src/index.js
              node --check services/balancer/src/index.js
              node --check services/notifications/src/index.js
              node --check services/deposits/src/index.js
              node --check services/transfers/src/index.js
              node --check services/analytics/src/index.js
              node --check services/ai/src/index.js
              node --check services/admin/src/index.js
            '''
          }
        }
      }
    }

    stage('Build Images') {
      steps {
        ansiColor('xterm') {
          dir(env.PROJECT_DIR) {
            sh '''
              set -eu
              for image in frontend gateway auth profile accounts balancer notifications deposits transfers analytics ai admin; do
                docker build -f $image/Dockerfile -t $ECR_REGISTRY/liontech-finance-$image:$IMAGE_TAG .
              done
            '''
          }
        }
      }
    }

    stage('Tag Latest') {
      steps {
        ansiColor('xterm') {
          dir(env.PROJECT_DIR) {
            sh '''
              set -eu
              for image in frontend gateway auth profile accounts balancer notifications deposits transfers analytics ai admin; do
                docker tag $ECR_REGISTRY/liontech-finance-$image:$IMAGE_TAG $ECR_REGISTRY/liontech-finance-$image:latest
              done
            '''
          }
        }
      }
    }

    stage('Push Images') {
      steps {
        ansiColor('xterm') {
          dir(env.PROJECT_DIR) {
            sh '''
              set -eu
              for image in frontend gateway auth profile accounts balancer notifications deposits transfers analytics ai admin; do
                docker push $ECR_REGISTRY/liontech-finance-$image:$IMAGE_TAG
                docker push $ECR_REGISTRY/liontech-finance-$image:latest
              done
            '''
          }
        }
      }
    }

    stage('Cleanup Docker Images') {
      steps {
        ansiColor('xterm') {
          sh '''
            set -eu
            echo "Cleaning up unused Docker images..."
            docker image prune -af || true
            docker container prune -f || true
          '''
        }
      }
    }

    // -------------------------------
    // Commented Kubernetes Deployment
    // -------------------------------
